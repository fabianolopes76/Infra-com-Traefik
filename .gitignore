# ---- Editores / IDEs ----
/.fleet
/.idea
/.nova
/.vscode
/.zed

# =============================================================
# Segredos e credenciais — NUNCA versionar.
# Regra geral: os arquivos reais ficam só na VPS (provisionados por ambiente);
# os modelos *.example continuam versionados como referência.
# =============================================================

# Variáveis de ambiente reais (mantém os *.example rastreados).
**/.env
**/*.env
!**/.env.example
!**/*.env.example

# Secrets em arquivo (ex.: cloudflare-token.secret, cloudflare-email.secret).
**/*.secret
!**/*.secret.example

# basicAuth do Traefik (hashes bcrypt do usersfile).
**/secrets/usersfile

# Alertmanager guarda o token do bot do Telegram.
# Versione um alertmanager.example.yml e mantenha o real fora do git.
infrastructure/prometheus/config/alertmanager.yml

# Certificados ACME (chaves privadas) — gerados/renovados em runtime pelo Traefik.
**/acme.json

# Chaves e certificados avulsos.
*.pem
*.key
